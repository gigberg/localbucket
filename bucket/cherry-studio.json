{
    "version": "1.9.9",
    "description": "A desktop client that supports for multiple LLM providers.",
    "homepage": "https://cherry-ai.com",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.9/Cherry-Studio-1.9.9-x64-setup.exe#/dl.7z",
            "hash": "sha512:98e30d903989b07dc3c97cbd45ef4f45f7e8d365d1bb753c1ed4d674d2e7b232564122cf83e73566e4a18f771f6da413e1f9cd816498d3e8d81626a5e1dcf839",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.9/Cherry-Studio-1.9.9-arm64-setup.exe#/dl.7z",
            "hash": "sha512:e871615af2de3c37a6b38c5a678b82a838d8291b54ad37321922c39a0c11187c4f1d1ccbac5441c0096df15f46f82a5f583427b75a76737745fd6ac127745c69",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\""
        }
    },
    "shortcuts": [
        [
            "Cherry Studio.exe",
            "Cherry Studio"
        ]
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Recurse",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name localbucket) scripts/LocalUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\CherryStudio\"",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\dotdata\" -Target \"$env:USERPROFILE\\.cherrystudio\"",
            "Remove-Module -Name LocalUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name localbucket) scripts/LocalUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\CherryStudio\"",
            "Dismount-ExternalRuntimeData -Target \"$env:USERPROFILE\\.cherrystudio\"",
            "Remove-Module -Name LocalUtils"
        ]
    },
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-x64-setup.exe#/dl.7z",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "(?s)x64.*?sha512: $base64"
                }
            },
            "arm64": {
                "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v$version/Cherry-Studio-$version-arm64-setup.exe#/dl.7z",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "(?s)arm64.*?sha512: $base64"
                }
            }
        }
    }
}
